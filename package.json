{
  "name": "budget-app-group59",
  "version": "1.0.0",
  "private": true,
  "description": "CPT304 CW1 Group 59 Budget Web App",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "badges": "npm-run-all --sequential badges:*",
    "badges:lines": "coverage-badges-cli --jsonPath total.lines.pct --label lines --output badges/coverage-lines.svg",
    "badges:statements": "coverage-badges-cli --jsonPath total.statements.pct --label statements --output badges/coverage-statements.svg",
    "badges:branches": "coverage-badges-cli --jsonPath total.branches.pct --label branches --output badges/coverage-branches.svg",
    "badges:functions": "coverage-badges-cli --jsonPath total.functions.pct --label functions --output badges/coverage-functions.svg"
  },
  "devDependencies": {
    "coverage-badges-cli": "^2.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "setupFiles": [
      "<rootDir>/tests/jest.setup.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "budget.js",
      "chart.js",
      "i18n.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "html",
      "lcov",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
